    {
      "name": "Pets - Public",
      "item": [
        {
          "name": "Get All Pets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pets?page=1&limit=12",
              "host": ["{{baseUrl}}"],
              "path": ["pets"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "12"
                }
              ]
            }
          }
        },
        {
          "name": "Search Pets by Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pets?search=Max&limit=12",
              "host": ["{{baseUrl}}"],
              "path": ["pets"],
              "query": [
                {
                  "key": "search",
                  "value": "Max"
                },
                {
                  "key": "limit",
                  "value": "12"
                }
              ]
            }
          }
        },
        {
          "name": "Filter Pets by Species",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pets?species=Dog&page=1&limit=12",
              "host": ["{{baseUrl}}"],
              "path": ["pets"],
              "query": [
                {
                  "key": "species",
                  "value": "Dog"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "12"
                }
              ]
            }
          }
        },
        {
          "name": "Get Pet Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pets/{{petId}}",
              "host": ["{{baseUrl}}"],
              "path": ["pets", "{{petId}}"]
            }
          }
        }
      ]
    },
