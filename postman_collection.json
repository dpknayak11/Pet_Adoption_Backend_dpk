              "raw": "{\n  \"name\": \"Max\",\n  \"species\": \"Dog\",\n  \"breed\": \"Golden Retriever\",\n  \"age\": 3,\n  \"gender\": \"Male\",\n  \"weight\": 32,\n  \"color\": \"Golden\",\n  \"image\": \"https://images.example.com/max.jpg\",\n  \"description\": \"Friendly and energetic Golden Retriever looking for an active family\",\n  \"traits\": [\"Friendly\", \"Energetic\", \"Loyal\", \"Good with kids\"],\n  \"health_status\": \"Healthy\",\n  \"microchip\": \"MC123456789\",\n  \"vaccinated\": true,\n  \"adopted\": false\n}"
